# Kopieer dit bestand naar `.env` (lokaal, niet committen).
# Alleen placeholders - vul geen echte secrets in dit bestand in.

# Playwright / lokale regressie - test admin (role=admin, status=active)
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
TEST_ADMIN_DISPLAY_NAME=

# Playwright / lokale regressie - active test member (role=member, status=active)
TEST_MEMBER_EMAIL=
TEST_MEMBER_PASSWORD=
TEST_MEMBER_DISPLAY_NAME=

# Seed / testdata - pending test member (role=member, status=pending)
TEST_MEMBER_PENDING_EMAIL=
TEST_MEMBER_PENDING_PASSWORD=
TEST_MEMBER_PENDING_DISPLAY_NAME=

# Seed / testdata - inactive test member (role=member, status=inactive)
TEST_MEMBER_INACTIVE_EMAIL=
TEST_MEMBER_INACTIVE_PASSWORD=
TEST_MEMBER_INACTIVE_DISPLAY_NAME=

# Statusmutatie test - apart testlid voor deactiveren/heractiveren flow
TEST_STATUS_MEMBER_EMAIL=
TEST_STATUS_MEMBER_PASSWORD=
TEST_STATUS_MEMBER_DISPLAY_NAME=

# Supabase-project voor lokale Playwright- en E2E-tests.
# Gebruik voor muterende tests uitsluitend het afgescheiden Supabase-testproject.
# Het seed-script gebruikt niet dit bestand, maar uitsluitend `.env.testdata`.
SUPABASE_URL=

# Alleen lokaal voor expliciet uitgevoerde Playwright- en E2E-beheertests.
# service_role omzeilt RLS: nooit committen, loggen of voor productiemutaties gebruiken.
# Het seed-script leest de service-role-key uitsluitend uit `.env.testdata`.
SUPABASE_SERVICE_ROLE_KEY=

# Profielbewerking test member
TEST_PROFILE_MEMBER_EMAIL=
TEST_PROFILE_MEMBER_PASSWORD=
TEST_PROFILE_MEMBER_DISPLAY_NAME=

# Create-member E2E testidentity - invite-flow, geen wachtwoord nodig
TEST_CREATE_MEMBER_E2E_ENABLED=false
TEST_CREATE_MEMBER_EMAIL=
TEST_CREATE_MEMBER_DISPLAY_NAME=

# Resend-member-invite E2E test - opt-in, kan echte reset/uitnodigingsmail versturen
TEST_RESEND_MEMBER_INVITE_E2E_ENABLED=false
