# Kopieer dit bestand naar `.env.testdata` voor lokaal seed- en testdatabeheer.
# `.env.testdata` wordt door Git genegeerd en mag echte lokale testsecrets bevatten.
# Dit bestand bevat uitsluitend veilige placeholders en de vaste URL van het afgescheiden testproject.

# Afgescheiden Supabase-testproject
SUPABASE_URL=https://lldmyfvhjypomxfpltlx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Test admin: role=admin, status=active
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
TEST_ADMIN_DISPLAY_NAME=

# Actief testlid: role=member, status=active
TEST_MEMBER_EMAIL=
TEST_MEMBER_PASSWORD=
TEST_MEMBER_DISPLAY_NAME=

# Pending testlid: role=member, status=pending
TEST_MEMBER_PENDING_EMAIL=
TEST_MEMBER_PENDING_PASSWORD=
TEST_MEMBER_PENDING_DISPLAY_NAME=

# Inactief testlid: role=member, status=inactive
TEST_MEMBER_INACTIVE_EMAIL=
TEST_MEMBER_INACTIVE_PASSWORD=
TEST_MEMBER_INACTIVE_DISPLAY_NAME=

# Apart testlid voor statusmutaties
TEST_STATUS_MEMBER_EMAIL=
TEST_STATUS_MEMBER_PASSWORD=
TEST_STATUS_MEMBER_DISPLAY_NAME=

# Apart testlid voor profielbewerking
TEST_PROFILE_MEMBER_EMAIL=
TEST_PROFILE_MEMBER_PASSWORD=
TEST_PROFILE_MEMBER_DISPLAY_NAME=
